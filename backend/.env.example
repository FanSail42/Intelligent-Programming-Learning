# 应用
APP_NAME=慧编学伴
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# 服务
HOST=0.0.0.0
PORT=8000

# CORS（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MySQL
DATABASE_URL=mysql+pymysql://huibian:huibian123@localhost:3306/huibian?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=4320
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM（Phase 2 起使用，阿里云百炼 / DashScope OpenAI 兼容模式）
# API Key：https://help.aliyun.com/zh/model-studio/get-api-key
# 模型列表：https://help.aliyun.com/zh/model-studio/getting-started/models
LLM_API_KEY=sk-your-dashscope-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-flash
CHAT_HISTORY_MAX_TURNS=10

# Embedding（Phase 2 起使用，可与 LLM 共用同一百炼 API Key）
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# ChromaDB（Phase 2 起使用）
CHROMA_PERSIST_DIR=./data/chroma

# 文件上传
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=20
