# 应用
APP_NAME=慧编学伴
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# 服务
HOST=0.0.0.0
PORT=8000

# CORS（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MySQL
DATABASE_URL=mysql+pymysql://huibian:huibian123@localhost:3306/huibian?charset=utf8mb4

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM（Phase 2 起使用）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Embedding（Phase 2 起使用）
EMBEDDING_API_KEY=sk-your-embedding-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# ChromaDB（Phase 2 起使用）
CHROMA_PERSIST_DIR=./data/chroma

# 文件上传
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=20
